{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": "."
  },
  "ts-node": {
    "preferTsExts": true
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "dist", "_data/families"]
}
