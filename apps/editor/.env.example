# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Authorization callback URL: http://localhost:3000/api/auth/callback/github (dev)
#                             https://your-editor.vercel.app/api/auth/callback/github (prod)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Required in production — set to your Vercel deployment URL
# Not needed locally (NextAuth infers it from the request)
AUTH_URL=https://your-editor.vercel.app

# The repo the editor reads/writes data from
GITHUB_REPO_OWNER=primavera133
GITHUB_REPO_NAME=dragonsGraphQLAPI
